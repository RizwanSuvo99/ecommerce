# ═══════════════════════════════════════════════════════════
# E-Commerce Web — Environment Variables
# ═══════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────
# Public (exposed to the browser)
# ─────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─────────────────────────────────────────────────────────
# Server-only
# ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ─────────────────────────────────────────────────────────
# Revalidation webhook (must match apps/api/.env REVALIDATE_SECRET)
# Used by /app/api/revalidate to authenticate cache-flush calls
# from the NestJS admin handlers.
# ─────────────────────────────────────────────────────────
REVALIDATE_SECRET="change-me-shared-with-web"
